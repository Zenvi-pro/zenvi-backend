# Zenvi — Product Launch Remotion Service
# Copy this file to .env and fill in the values.

# Server port (default: 3100)
PORT=3100

# Supabase — required for uploading rendered videos to the "product_demo" bucket.
# Use the service-role key (not the anon key) so the server can write to storage.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
