# Zenvi Backend — Environment Configuration
# Copy this file to .env and fill in your API keys.

# Server
ZENVI_HOST=0.0.0.0
ZENVI_PORT=8500
ZENVI_DEBUG=false
ZENVI_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Google
# GOOGLE_API_KEY is used by any future Google Generative AI (Gemini) provider.
# GOOGLE_APPLICATION_CREDENTIALS was used by the Google Cloud Vision provider in the
# original core/ desktop app (google-cloud-vision SDK). That provider has NOT been
# ported to zenvi-backend — leave blank unless you add a Cloud Vision route.
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# AWS
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY were used by the AWS Rekognition provider
# in the original core/ desktop app (boto3). That provider has NOT been ported to
# zenvi-backend — leave blank unless you add a Rekognition route.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# TwelveLabs
TWELVELABS_API_KEY=

# Runware (video generation — Kling model)
RUNWARE_API_KEY=

# Perplexity (research agent)
PERPLEXITY_API_KEY=

# GitHub (product launch agent)
GITHUB_TOKEN=

# Suno (music agent)
SUNO_COOKIE=

# NVIDIA Edge Device (optional — for local GPU inference)
# NVIDIA_EDGE_URL=http://YOUR_EDGE_DEVICE:8000

# Remotion Rendering Services (optional — for animated video rendering)
REMOTION_URL=http://localhost:4500/api/v1
REMOTION_PRODUCT_LAUNCH_URL=http://localhost:3100

# Agent config
ZENVI_DEFAULT_MODEL=openai/gpt-4o-mini
ZENVI_AGENT_MAX_ITERATIONS=15
ZENVI_AGENT_TIMEOUT=120

# Supabase (usage tracking + tier enforcement — Phase 4)
# SUPABASE_URL is the project URL shown in your Supabase dashboard.
# SUPABASE_ANON_KEY is the public anon key (safe to ship — row-level security enforces access).
SUPABASE_URL=https://fmeawyasfffvyoactenu.supabase.co
SUPABASE_ANON_KEY=

# Stock Video API (Pexel)
PEXELS_API_KEY=

# Vector DB Key (Pincone)
PINECONE_API_KEY=