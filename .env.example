# Zenvi Backend — Environment Configuration
# Copy this file to .env and fill in your API keys.

# Server
ZENVI_HOST=0.0.0.0
ZENVI_PORT=8500
ZENVI_DEBUG=false
ZENVI_CORS_ORIGINS=*

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Google
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# TwelveLabs
TWELVELABS_API_KEY=

# Runware (video generation)
RUNWARE_API_KEY=

# Agent config
ZENVI_DEFAULT_MODEL=openai/gpt-4o-mini
ZENVI_AGENT_MAX_ITERATIONS=15
ZENVI_AGENT_TIMEOUT=120
